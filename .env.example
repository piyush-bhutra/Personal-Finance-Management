# Core App configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name

# Authentication
# You can generate a JWT secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=30d

# Email Service (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Frontend Navigation URLs 
# Either FRONTEND_URL or CLIENT_URL can be used to ensure email link generation redirects to the correct host
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
